# Stripe Configuration
# Get these from your Stripe dashboard
STRIPE_SECRET_KEY=sk_test_your_test_secret_key_here_or_sk_live_for_production
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here
PROTOVID_PRICE_ID=price_your_stripe_price_id_here

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database Configuration
# Get this from your Neon/Postgres provider
NEON_DATABASE_URL=postgresql://username:password@host:port/database?sslmode=require

# Stats API Key (generate a secure random string)
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
STATS_API_KEY=your_secure_random_api_key_here

# Security Configuration
NODE_ENV=development